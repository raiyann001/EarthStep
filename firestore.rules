// ==========================================================================
// EarthStep — Firestore Security Rules (full app scope)
// --------------------------------------------------------------------------
// Paste this into Firebase Console → Firestore Database → Rules, then
// "Publish". This REPLACES the earlier Step-1-only rules file — it's a
// superset, so nothing from before breaks.
//
// This is the real access boundary for the whole app: the admin panel's
// UI check (assets/js/admin.js) is just for a clean experience — someone
// bypassing the UI still can't write to /challenges, /announcements, or
// /badges unless their own users/{uid}.role field is "admin", which can
// only be set manually in the Firestore console (never from client code).
// ==========================================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ---- User profiles ----
    match /users/{uid} {
      // Signed-in users can read any profile (needed for the public
      // leaderboard). Only the owner can create/update their own doc.
      // `role` can only ever be set to 'admin' by an existing admin, never
      // by the user themself — see the update rule below.
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid
                    && request.resource.data.role == 'user';
      allow update: if isSignedIn() && request.auth.uid == uid
                    && request.resource.data.role == resource.data.role; // can't self-promote
      allow update: if isAdmin(); // admins can adjust any profile (e.g. role)
      allow delete: if false;

      // Per-day challenge completion record — owner only, never public.
      match /completions/{dateKey} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }
    }

    // ---- Daily challenges ----
    match /challenges/{challengeId} {
      allow read: if true; // public — the homepage shows today's challenges to guests too
      allow write: if isAdmin(); // create, edit, delete
    }

    // ---- Announcements ----
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---- Badge catalog (reference/display data) ----
    match /badges/{badgeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Everything else stays locked by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
